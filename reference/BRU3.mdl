//-------------------------------------------------
// Closed Brayton 10.5kW Bru Model: Based on State Points
//-------------------------------------------------

///Notes : Current issue seem the 1701 R, look at Interstage Bleed Port

//Declearing thermo package and 
#include <ncp.view>
//setThermoPackage("CEA", "thermo.inp", "trans.inp", "He", "Xe");
setThermoPackage("FPT");



// Creating FlowStations
FlowStation fs;

// Setting FlowStation Composition using HeXe.fpt
//fs.comp = "HeXe84";
fs.comp = "CEAT";

// Effect of Operating Params on Net Power Output of a 2-10KW Brayton Rotating Unit(1970)
Element HeXeStart Start {// Good
	Pt = 23.7; //  0.1634057 "MPa"
	Tt = 540; //Rankine
	Wflow = 1.32; 
	//Fl_O.comp = "HeXe84"; // MW 83.8
	Fl_O.comp = "CEAT"; 
	 
	
   	
	//void postexecute(){
	//Fl_O.Wreac1 = .0181;
	//Fl_O.Wreac2 = .9819;
	//Fl_O.setTotalTP(Tt,Pt);
	//}

}

Element Compressor Comp {// Good
	PRdes = 1.9;
	effDes = 0.80;
	real pwrkW;
	
	void postexecute () {
		Bld.setTotalTP(459.+100.,Bld.Pt);
		pwrkW = 0.7457*pwr;
	
	}
	
	
	InterStageBleedOutPort Bld {// Good
		fracBldW = 0.02;
		fracBldP = 1;
	}
	
}

Element HeXeStart HotStart { // Good
	Pt = 24.69; // psia hot side
	Tt = 1701;// R
	Wflow = 1.32 ; // 1.28 lb/s hot side flow : changed due o inconsistency in weight flows
	//Fl_O.comp = "HeXe84";
	Fl_O.comp = "CEAT";
	
	ind_W.autoSetup = FALSE;
	ind_Pt.autoSetup = TRUE;
	
	
	/*
    void postexecute(){
      cerr << Fl_I.W << " " << Fl_O.W << endl;
      cerr << Fl_I.Pt << " " << Fl_O.Pt << endl;
      cerr << Fl_I.Tt << " " << Fl_O.Tt << endl;  
    }
	*/
}



Element HeatExchanger Recup { // May have to calculate Pressure Drop -> 100*(Pin-Pout)/Pin
	dPqP1 = 0.011;// High Pressure Side Pdrop
	dPqP2 = 0.022;// Low Pressure Side Pdrop
	effect = 0.95;// EZ Sizer
	
}

Element HeXeStart Dow200Start {// 
	Pt = 6 + 14.7;
	Tt =  527;
	Wflow = 0.14;
	Fl_O.comp = "Oil";
	
}

Element Pump_x Pump { // make sure untis work// Good
	GPM = 3.7;
	SPEED = 11200;
	EFF= 0.26; 
	// 6 psig is from pump inlet from pg 83 of "Design and Preliminary Testing of a Brayton Space Radiator Concept"
	Pout = 70 + 14.2 + 6; 
	
	Independent ind_PRdes{
      varName = "Pout";
      autoSetup = TRUE;
    }
	
	void postexecute () {
		//quit();
	}
	void preexecute () {
		cerr << Fl_I.W << " " << Fl_I.Tt << " " << Fl_I.Pt << endl;
		
	}
}


Element HeatExchanger HeatSinkHx {
  dPqP1 = ( 14.45-14.2 )/14.45;
  dPqP2 = 0.005;	// Pressure Drop
 effect =  0.946;// EZ Sizer
	
}



Element Duct HeatSourceHX {
	switchDP = "INPUT";
    dPqP_in = 0.027;
    
	
	
	//effect = 0.95 ;// Assumption
	
	switchQ = "INPUT";
    //Q_in = 33.1"kW";
	real Tout = 2060;
	
	void postexecute() {
	Fl_O.setTotalTP(Tout,Fl_O.Pt);	
    }
		
    
}

Element SimpleRadiator Radiator { 
	Ts = 414.82 "K"; //sink temp
	Tout = 527; // Sandusky Test
	dP = 69.5;
	//area = .2;
}




Element Turbine Turb {
	PRdes = 1.75;
	effDes = 0.87;
	real pwrkW;
	
	void postexecute() {
	pwrkW = 0.7457*pwr;
	}
	
	Independent ind_PRdes{
      varName = "PRdes";
      autoSetup = TRUE;
    }
	
InterStageBleedInPort Bld {
		Pfract = 0.;
	}
	
}

Element Shaft HPshaft {
	ShaftInputPort HPClink;
	ShaftInputPort HPTlink;
	HPX = 10.9/.92+.65+.236+.272+.064+.1+.05+.2 "kW"; //alternator power output in horsepower
    cerr << "HPX " << HPX*.7457 << endl;
	Nmech = 36000;
	
}


// Linking Elements Together
//Start-Comp-Recup-HeatSource-Turbine-Start
linkPorts("Start.Fl_O",           "Comp.Fl_I",            "station0");
linkPorts("Comp.Fl_O",            "Recup.Fl_I1",        "station1");
linkPorts("Comp.Bld",             "Turb.Bld",              "station2");
linkPorts("Recup.Fl_O1",           "HeatSourceHX.Fl_I",    "station4");
linkPorts("HeatSourceHX.Fl_O",    "Turb.Fl_I",            "station5");
linkPorts("Turb.Fl_O",            "HotStart.Fl_I",        "station6");
linkPorts("HotStart.Fl_O",        "Recup.Fl_I2",          "station7");
linkPorts("Recup.Fl_O2",           "HeatSinkHx.Fl_I1",    "station8");
linkPorts("HeatSinkHx.Fl_O1",       "Start.Fl_I",           "station9");
   



//Radiator Loop
linkPorts("Dow200Start.Fl_O",       "Pump.Fl_I",              "station10");
linkPorts("Pump.Fl_O",              "HeatSinkHx.Fl_I2",       "station11");
linkPorts("HeatSinkHx.Fl_O2",       "Radiator.Fl_I",           "station12");
linkPorts("Radiator.Fl_O",              "Dow200Start.Fl_I",    "station13");

//Shaft
linkPorts( "Comp.Sh_O",         "HPshaft.HPClink",  "HPCwork"  );
linkPorts( "Turb.Sh_O",         "HPshaft.HPTlink",  "HPTwork"  );


// printing "elements linked" statement
cout << "Elements Linked!" << endl;

/*	
// Instantiating Solver Objects
Independent ind_myTurbine {
	varName ="myTurbine.PRdes";
}

Dependent dep_PowerBalance {
	eq_lhs = "-myCompressor.pwr";
	eq_rhs = "myTurbine.pwr";
}

*/





//setting model design mode to run closed Brayton model Design point
setOption( "switchDes", "DESIGN" );
setOption( "switchInputSet", "USER" );
//Start.ind_Tt.autoSetup = FALSE;
Independent ind_StartW {
	varName = "Start.Wflow";
	//autoSetup = TRUE;
}

Dow200Start.dep_Tt.autoSetup = FALSE;
Start.ind_Tt.autoSetup = FALSE;


Independent ind_DowStartW {
	varName = "Dow200Start.Wflow";
	//autoSetup = TRUE;
}

Independent ind_WHEXEFF {
	varName = "HeatSinkHx.effect";
	//autoSetup = TRUE;
}

Independent ind_HPX {
	varName = "HPshaft.HPX";
	autoSetup = FALSE;
}

Independent ind_HeatSource {
	varName = "HeatSourceHX.Tout";
	autoSetup = TRUE;
}

Independent ind_radArea {
	varName = "Radiator.area";
	//autoSetup = TRUE;
}

//Pump.ind_PRdes.autoSetup = FALSE;
//Dow200Start.dep_Pt.autoSetup = FALSE;
//Start.ind_Tt.autoSetup = FALSE;


autoSolverSetup();
//solver.debugLevel="ITERATION_DETAILS";
// execute DESIGN point

solver.debugLevel= "ITERATION_DETAILS";
solver.diagnosticFile = "solver.bad";
solver.maxIterations = 1000;
solver.maxJacobians = 1000;
//solver.clear();
run();

addUnitPref("hp", "kW");
ncpView.display();

cerr << "Turbine is Isolation\n";
Turb.Fl_I.setTotalTP( 2060., 43.2 );
Turb.Fl_I.W =  1.31;
Turb.PRdes = 43.2/24.69;
Turb.calculate();

cout << Turb.Fl_O.Tt << " " << Turb.Fl_O.Pt << endl << endl;

cout << "Recup in isolation\n";
Recup.Fl_I1.setTotalTP( 737., 45.03 );
Recup.Fl_I1.W = 1.267;
Recup.Fl_I2.setTotalTP( 1701., 24.68 );
Recup.Fl_I2.W = 1.28;

cout << Recup.Fl_O1.Tt << " " << Recup.Fl_O2.Tt <<endl;

cout << HeatSinkHx.Fl_I1.Tt << endl;
cout << "HeatSinkHx in isolation\n";
HeatSinkHx.Fl_I1.setTotalTP( 786., HeatSinkHx.Fl_O1.Pt );
HeatSinkHx.Fl_I1.W = 1.267;
HeatSinkHx.Fl_I2.setTotalTP( 527., HeatSinkHx.Fl_O2.Pt );
HeatSinkHx.Fl_I2.W = 1.28;

cout << HeatSinkHx.Fl_O1.Tt << " " << HeatSinkHx.Fl_O2.Tt <<endl;

//run();
//ncpView.display();
//page.display();