I think//-------------------------------
//----------BRU HeatSink HX------------
//---------------------------------

//Declaring Thermo Package and Viewer
#include <ncp.view>
setThermoPackage("FPT");

// Creating FlowStations
FlowStation fs;

//Setting FlowStation Composition using HeXe.fpt

Element FlowStart HotStart { // Good
	Pt = 24; // psia hot side
	Tt = 786; 
	W = 1.28; // lb/s hot side flow
	Fl_O.comp = "HeXeT"; // 83.8
	
	
	/*
    void postexecute(){
      cerr << Fl_I.W << " " << Fl_O.W << endl;
      cerr << Fl_I.Pt << " " << Fl_O.Pt << endl;
      cerr << Fl_I.Tt << " " << Fl_O.Tt << endl;  
    }
	*/
}

Element FlowStart ColdStart { // Good
	Pt = 90.7; // psia cold side
	Tt = 527; // R cold side
	W = 0.14; // lb/s cold side flow
	Fl_O.comp = "Oil";
	
}

Element HeatExchanger HeatSink {
	dPqP1 = 0.005;
    dPqP2 = 0.005;	// Pressure Drop
	effect =  0.946;// EZ Sizer
	
}


Element FlowEnd ColdEnd {
	
}

Element FlowEnd HotEnd {
	
}
	
// Linking Elements 
linkPorts("ColdStart.Fl_O",         "HeatSink.Fl_I1",      "station0");
linkPorts("HotStart.Fl_O",          "HeatSink.Fl_I2",      "station1");
linkPorts("HeatSink.Fl_O1",            "ColdEnd.Fl_I",      "station2");
linkPorts("HeatSink.Fl_O2",            "HotEnd.Fl_I",      "station3");

run();


ncpView.display();